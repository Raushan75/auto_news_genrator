// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(READER)
  password      String?   // hashed, null for OAuth users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  bookmarks  Bookmark[]
  comments   Comment[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── NEWS ─────────────────────────────────────────────────────────────────────

model RssFeed {
  id          String   @id @default(cuid())
  name        String
  url         String   @unique
  category    Category
  isActive    Boolean  @default(true)
  lastFetched DateTime?
  fetchCount  Int      @default(0)
  errorCount  Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@index([isActive])
  @@index([category])
}

model Article {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  originalTitle  String?
  excerpt        String        @db.Text
  content        String        @db.Text
  originalContent String?      @db.Text
  imageUrl       String?
  imageAlt       String?
  author         String?
  sourceUrl      String?
  sourceName     String?
  category       Category
  tags           String[]
  status         ArticleStatus @default(DRAFT)
  isAiRewritten  Boolean       @default(false)
  isFeatured     Boolean       @default(false)
  isBreaking     Boolean       @default(false)
  viewCount      Int           @default(0)
  readTime       Int           @default(0)  // minutes
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  feedId    String?
  feed      RssFeed?   @relation(fields: [feedId], references: [id])
  bookmarks Bookmark[]
  comments  Comment[]

  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([publishedAt])
  @@index([isFeatured])
  @@index([isBreaking])
  @@index([viewCount])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
}

model Comment {
  id        String        @id @default(cuid())
  content   String        @db.Text
  status    CommentStatus @default(PENDING)
  userId    String
  articleId String
  parentId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parent  Comment? @relation("Replies", fields: [parentId], references: [id])
  replies Comment[] @relation("Replies")

  @@index([articleId])
  @@index([userId])
  @@index([status])
}

// ─── NEWSLETTER ───────────────────────────────────────────────────────────────

model Subscriber {
  id          String             @id @default(cuid())
  email       String             @unique
  name        String?
  status      SubscriberStatus   @default(PENDING)
  token       String             @unique @default(cuid())
  categories  Category[]
  frequency   EmailFrequency     @default(DAILY)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  confirmedAt DateTime?

  @@index([email])
  @@index([status])
}

// ─── SEO ──────────────────────────────────────────────────────────────────────

model SeoMeta {
  id          String   @id @default(cuid())
  path        String   @unique
  title       String
  description String   @db.Text
  keywords    String[]
  ogImage     String?
  canonical   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  READER
  EDITOR
  ADMIN
}

enum Category {
  WORLD
  TECHNOLOGY
  FINANCE
  POLITICS
  SCIENCE
  CLIMATE
  HEALTH
  CULTURE
  SPORTS
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
}

enum EmailFrequency {
  REALTIME
  DAILY
  WEEKLY
}
